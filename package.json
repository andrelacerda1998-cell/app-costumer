{
  "name": "piquet-client",
  "main": "expo-router/entry",
  "version": "2026.7.21",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android --device",
    "ios": "expo run:ios --device",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "prebuild:clean": "rm -rf android ios",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "build-local:ios:production": "APP_ENV=production yarn prebuild:ios && open ios/Piquet.xcworkspace",
    "build-local:ios:preview": "APP_ENV=preview yarn prebuild:ios && open ios/Piquet.xcworkspace",
    "build-local:android": "yarn prebuild:android && cd android && ./gradlew clean && ./gradlew assembleRelease && cd .. && open android/app/build/outputs/apk/release",
    "build-local:android:production": "APP_ENV=production yarn build-local:android",
    "build-local:android:preview": "APP_ENV=preview yarn build-local:android",
    "build-local:android:development": "APP_ENV=development yarn build-local:android",
    "build-local:android:bundle": "yarn prebuild:android && cd android && ./gradlew clean && ./gradlew bundleRelease && cd .. && open android/app/build/outputs/bundle/release",
    "eas-build-preview:ios": "eas build --platform ios --profile preview",
    "eas-build-preview:android": "eas build --platform android --profile preview",
    "postinstall": "patch-package" 
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.2.3",
    "@expo/config-plugins": "~9.0.0",
    "@expo/react-native-action-sheet": "^4.1.0",
