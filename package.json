    "@react-native-picker/picker": "2.9.0",
    "@react-navigation/native": "^7.0.0",
    "@sentry/react-native": "~6.10.0",
    "advanced-html-parser": "^1.1.0",
    "axios": "^1.16.0",
    "card-validator": "^10.0.0",
